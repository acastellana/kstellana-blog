---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="container" style="text-align: center; padding: 4rem 1.5rem;">
    <p style="font-size: 5rem; margin-bottom: 1rem;">404</p>
    <h1 style="font-size: 1.5rem; margin-bottom: 1rem;">Page not found</h1>
    <p style="color: var(--color-text-muted); margin-bottom: 2rem;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/" class="btn">Go home</a>
  </div>
</BaseLayout>
